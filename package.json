    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.18",
    "@sentry/react": "^10.62.0",
    "@stripe/stripe-js": "^9.8.0",
    "@tanstack/react-query": "^5.101.2",
    "@types/js-cookie": "^3.0.6",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
